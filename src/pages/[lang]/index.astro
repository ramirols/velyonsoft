const sectionIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l1.8 6.1L20 10l-6.2 1.9L12 18l-1.8-6.1L4 10l6.2-1.9L12 2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M19 15l.8 2.7L22.5 18l-2.7.8L19 21.5l-.8-2.7-2.7-.8 2.7-.8L19 15Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>`;
const automationFallbackSvg = `<svg class="lottie-fallback-svg" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle class="fallback-ring" cx="160" cy="160" r="94" stroke="currentColor" stroke-width="10" opacity="0.3"/><path class="fallback-orbit" d="M82 138L160 230L244 132Z" stroke="currentColor" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" opacity="0.82"/><circle cx="82" cy="138" r="24" fill="currentColor"/><circle cx="160" cy="230" r="30" fill="var(--background)" stroke="currentColor" stroke-width="9"/><circle cx="244" cy="132" r="24" fill="currentColor"/></svg>`;
const growthFallbackSvg = `<svg class="lottie-fallback-svg" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect class="fallback-bar fallback-bar-1" x="60" y="162" width="48" height="98" rx="16" fill="currentColor" opacity="0.9"/><rect class="fallback-bar fallback-bar-2" x="136" y="116" width="48" height="144" rx="16" fill="var(--primary)" opacity="0.88"/><rect class="fallback-bar fallback-bar-3" x="212" y="68" width="48" height="192" rx="16" fill="currentColor" opacity="0.9"/><path class="fallback-line" d="M70 134C112 128 130 90 160 94C194 98 204 56 252 50" stroke="currentColor" stroke-width="8" stroke-linecap="round"/></svg>`;
const seoFallbackSvg = `<svg class="lottie-fallback-svg" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle class="fallback-ring" cx="160" cy="160" r="104" stroke="currentColor" stroke-width="13" opacity="0.35"/><path class="fallback-check" d="M104 162L144 204L224 112" stroke="currentColor" stroke-width="18" stroke-linecap="round" stroke-linejoin="round"/><circle cx="160" cy="160" r="124" stroke="currentColor" stroke-width="2" opacity="0.16" stroke-dasharray="10 12"/></svg>`;

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${homeUrl}#webpage`,
      url: homeUrl,
      name: t.title,
      description: t.description,
      inLanguage: lang,
      isPartOf: { "@id": `${site}/#website` },
      about: [
        "desarrollo de software a medida",
        "automatizacion de procesos",
        "desarrollo web para empresas",
        "SEO tecnico",
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${homeUrl}#services`,
      name:
        lang === "es"
          ? "Servicios digitales de VelyonSoft"
          : "VelyonSoft digital services",
      itemListElement: t.services.map((service, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: service.title,
        url: `${site}${service.href}`,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${homeUrl}#faq`,
      mainEntity: t.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title={t.title}
  description={t.description}
  image="/home.webp"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <Hero lang={lang} />

  <section
    class="home-shell relative overflow-hidden bg-background py-16 sm:py-20 lg:py-28"
    aria-labelledby="home-intro-title"
  >
    <div class="pointer-events-none absolute inset-0 home-grid"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div>
          <div class="home-badge">
            <span set:html={sectionIcon} />
            {t.badge}
          </div>

          <h2
            id="home-intro-title"
            class="mt-6 max-w-4xl text-3xl font-black leading-[1.02] tracking-tight text-primary sm:text-5xl lg:text-6xl"
          >
            {t.introTitle}
          </h2>

          <div class="mt-7 flex flex-wrap gap-3">
            <div class="mini-proof">
              <SearchCheck size={18} />
              <span>{lang === "es" ? "SEO técnico" : "Technical SEO"}</span>
            </div>
            <div class="mini-proof">
              <Gauge size={18} />
              <span>{lang === "es" ? "Web rápida" : "Fast website"}</span>
            </div>
            <div class="mini-proof">
              <LineChart size={18} />
              <span>{lang === "es" ? "Más consultas" : "More inquiries"}</span>
            </div>
          </div>
        </div>

        <article
          class="relative overflow-hidden rounded-[2rem] border border-border/70 bg-card/70 p-6 shadow-2xl shadow-black/5 backdrop-blur-xl sm:p-8"
          aria-label={lang === "es"
            ? "Resumen de servicios digitales de VelyonSoft"
            : "Summary of VelyonSoft digital services"}
        >
          <div
            class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-secondary/10 blur-3xl"
          >
          </div>

          <p class="relative text-[17px] leading-[1.95] text-muted-foreground">
            {t.introText}
          </p>

          <div class="relative mt-7 grid gap-3 sm:grid-cols-2">
            <p
              class="rounded-2xl border border-border/70 bg-background/70 p-4 text-[15px] leading-[1.9] text-muted-foreground"
            >
              <strong class="block">
                {
                  lang === "es"
                    ? "Para empresas que necesitan clientes"
                    : "For companies that need clients"
                }
              </strong>
              {
                lang === "es"
                  ? "Sitios preparados para posicionar, explicar servicios y generar confianza."
                  : "Websites built to rank, explain services and build trust."
              }
            </p>

            <p
              class="rounded-2xl border border-border/70 bg-background/70 p-4 text-[15px] leading-[1.9] text-muted-foreground"
            >
              <strong class="block">
                {
                  lang === "es"
                    ? "Para negocios que quieren escalar"
                    : "For businesses ready to scale"
                }
              </strong>
              {
                lang === "es"
                  ? "Software y automatizaciones para operar con más orden y menos tareas manuales."
                  : "Software and automations to operate with more control and less manual work."
              }
            </p>
          </div>
        </article>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          t.impactCards.map((card) => (
            <article class="metric-card group">
