<script>
    import lottie from "lottie-web/build/player/lottie_light";

    const mountHomeLotties = () => {
        document.querySelectorAll("[data-lottie-src]").forEach((element) => {
            if (!(element instanceof HTMLElement) || element.dataset.lottieMounted === "true") {
                return;
            }

            const src = element.dataset.lottieSrc;
            const frame = element.closest("[data-lottie-frame]");

            if (!src || !(frame instanceof HTMLElement)) {
                return;
            }

            element.dataset.lottieMounted = "true";

            try {
                const animation = lottie.loadAnimation({
                    container: element,
                    renderer: "svg",
                    loop: true,
                    autoplay: true,
                    path: src,
                    rendererSettings: {
                        preserveAspectRatio: "xMidYMid meet",
                        progressiveLoad: true,
                    },
                });

                animation.addEventListener("DOMLoaded", () => {
                    frame.classList.add("is-lottie-loaded");
                });

                animation.addEventListener("data_failed", () => {
                    frame.classList.add("is-lottie-fallback");
                    element.dataset.lottieMounted = "failed";
                });
            } catch {
                frame.classList.add("is-lottie-fallback");
                element.dataset.lottieMounted = "failed";
            }
        });
    };

    mountHomeLotties();
    document.addEventListener("astro:page-load", mountHomeLotties);
</script>

