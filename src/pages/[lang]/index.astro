<script>
  const homeLottieLightContrast = "#00677c";
  const reduceMotionMedia = window.matchMedia("(prefers-reduced-motion: reduce)");
  let lottieModulePromise;

  const getLottie = () => {
    if (!lottieModulePromise) {
      lottieModulePromise = import("lottie-web").then((module) => module.default ?? module);
    }

    return lottieModulePromise;
  };

  const normalizeLottieColor = (value = "") =>
    value.replace(/\s+/g, "").toLowerCase();

  const isThemeSensitiveLottieColor = (value = "") => {
    const normalizedValue = normalizeLottieColor(value);

    return (
      normalizedValue === "#fff" ||
      normalizedValue === "#ffffff" ||
      normalizedValue === "rgb(255,255,255)" ||
      normalizedValue === homeLottieLightContrast ||
      normalizedValue === "rgb(0,103,124)"
    );
  };

  const markThemeSensitiveLottieShapes = (frame) => {
    if (!(frame instanceof HTMLElement)) {
      return;
    }

    frame
      .querySelectorAll("svg [fill], svg [stroke], svg [style]")
      .forEach((shape) => {
        if (!(shape instanceof SVGElement)) {
          return;
        }

        const fillValue =
          shape.style.getPropertyValue("fill") ||
          shape.getAttribute("fill") ||
          "";
        const strokeValue =
          shape.style.getPropertyValue("stroke") ||
          shape.getAttribute("stroke") ||
          "";

        if (isThemeSensitiveLottieColor(fillValue)) {
          shape.dataset.lottieThemeFill = "true";
        }

        if (isThemeSensitiveLottieColor(strokeValue)) {
          shape.dataset.lottieThemeStroke = "true";
        }
      });
  };

  const syncHomeLottieColors = () => {
    const targetColor = document.documentElement.classList.contains("dark")
      ? "#ffffff"
      : homeLottieLightContrast;

    document.querySelectorAll("[data-lottie-frame]").forEach((frame) => {
      if (!(frame instanceof HTMLElement)) {
        return;
      }

      markThemeSensitiveLottieShapes(frame);

      frame
        .querySelectorAll(
          "svg [data-lottie-theme-fill], svg [data-lottie-theme-stroke]",
        )
        .forEach((shape) => {
          if (!(shape instanceof SVGElement)) {
            return;
          }

          if (shape.dataset.lottieThemeFill === "true") {
            shape.setAttribute("fill", targetColor);
            shape.style.setProperty("fill", targetColor);
          }

          if (shape.dataset.lottieThemeStroke === "true") {
            shape.setAttribute("stroke", targetColor);
            shape.style.setProperty("stroke", targetColor);
          }
        });
    });
  };

  const showAllLottieFallbacks = () => {
    document.querySelectorAll("[data-lottie-frame]").forEach((frame) => {
      if (frame instanceof HTMLElement) {
        frame.classList.add("is-lottie-fallback");
      }
    });
  };

  const mountHomeLotties = async () => {
    if (reduceMotionMedia.matches) {
      showAllLottieFallbacks();
      return;
    }

    const lottie = await getLottie();

    document.querySelectorAll("[data-lottie-src]").forEach((element) => {
      if (
        !(element instanceof HTMLElement) ||
        element.dataset.lottieMounted === "true"
      ) {
        return;
      }

      const src = element.dataset.lottieSrc;
      const frame = element.closest("[data-lottie-frame]");

      if (!src || !(frame instanceof HTMLElement)) {
        return;
      }

      element.dataset.lottieMounted = "true";

      const showLoaded = () => {
        frame.classList.add("is-lottie-loaded");
        frame.classList.remove("is-lottie-fallback");
      };

      const showFallback = () => {
        frame.classList.add("is-lottie-fallback");
        element.dataset.lottieMounted = "failed";
      };

      try {
        const animation = lottie.loadAnimation({
          container: element,
          renderer: "svg",
          loop: true,
          autoplay: true,
          path: src,
          rendererSettings: {
            preserveAspectRatio: "xMidYMid meet",
            progressiveLoad: false,
          },
        });

        animation.addEventListener("DOMLoaded", () => {
          syncHomeLottieColors();
          showLoaded();
        });
        animation.addEventListener("data_ready", showLoaded);
        animation.addEventListener("config_ready", showLoaded);
        animation.addEventListener("data_failed", showFallback);
      } catch (error) {
        console.error("Lottie mount error:", error);
        showFallback();
      }
    });
  };

  const scheduleHomeLotties = () => {
    const run = () => {
      mountHomeLotties();
      syncHomeLottieColors();
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(run, { timeout: 1600 });
      return;
    }

    window.setTimeout(run, 500);
  };

  scheduleHomeLotties();

  if (!window.__homeLottieThemeSyncBound) {
    window.__homeLottieThemeSyncBound = true;
    document.addEventListener("themechange", syncHomeLottieColors);
    document.addEventListener("astro:page-load", () => {
      scheduleHomeLotties();
    });

    if (reduceMotionMedia.addEventListener) {
      reduceMotionMedia.addEventListener("change", scheduleHomeLotties);
    } else {
      reduceMotionMedia.addListener(scheduleHomeLotties);
    }
  }
</script>

