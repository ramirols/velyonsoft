---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
	return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<BaseLayout
	lang={lang}
	title={lang === "es"
		? "Desarrollo de software a medida, automatizacion y SEO en Peru | VelyonSoft"
		: "Custom software, automation and SEO in Peru | VelyonSoft"}
	description={lang === "es"
		? "VelyonSoft desarrolla software a medida, webs corporativas, tiendas virtuales y automatizaciones para empresas en Peru con enfoque en SEO tecnico y conversion."
		: "VelyonSoft builds custom software, corporate websites, online stores and automations in Peru with technical SEO and conversion in mind."}
	image="/home.webp"
>
	<Hero lang={lang} />
</BaseLayout>
