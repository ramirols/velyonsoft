---
import {
    ArrowRight,
    Building2,
    CheckCircle2,
    Gauge,
    LineChart,
    SearchCheck,
    Sparkles,
    Workflow,
} from "lucide-astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getWhatsAppLinkWithMessage } from "@/lib/constants";

export function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

type Language = "es" | "en";

const { lang } = Astro.params as { lang: Language };

const site = "https://www.velyonsoft.com";
const pageUrl = `${site}/${lang}/sobre-nosotros`;
const quoteHref = getWhatsAppLinkWithMessage(
    lang === "es"
        ? "Hola VelyonSoft, quiero conversar sobre una solución digital para mi empresa."
        : "Hello VelyonSoft, I want to talk about a digital solution for my company.",
);
const projectsHref = `/${lang}/proyectos`;

const philosophyIcons = [Sparkles, Workflow, CheckCircle2];
const reasonIcons = [SearchCheck, Sparkles, LineChart, Gauge];
const valueIcons = [Workflow, SearchCheck, Building2];

const t = {
    es: {
        title: "Sobre Nosotros | Desarrollo web, SEO y software | VelyonSoft",
        description:
            "Conoce a VelyonSoft: desarrollo web, SEO técnico y software optimizado para empresas que quieren vender mejor y escalar con claridad.",
        breadcrumbHome: "Inicio",
        breadcrumbCurrent: "Sobre nosotros",
        hero: {
            badge: "Quiénes somos",
            titleLines: [
                { text: "Dirigido por ingeniería.", accent: false },
                { text: "Centrado en la ejecución.", accent: true },
            ],
            body: "VelyonSoft es un estudio de desarrollo web, software a medida y SEO técnico. Diseñamos, construimos y optimizamos plataformas digitales para empresas que quieren vender mejor, operar con más claridad y escalar con una base sólida.",
            primary: "Contáctanos",
            secondary: "Ver proyectos",
            stats: [
                {
                    value: "+5",
                    label: "Años de Innovación",
                    detail: "Soluciones digitales construidas con foco real de negocio",
                },
                {
                    value: "+50",
                    label: "Casos de Éxito",
                    detail: "Proyectos lanzados para marcas y empresas que necesitaban claridad",
                },
                {
                    value: "100%",
                    label: "SEO",
                    detail: "Arquitectura técnica, velocidad y semántica alineadas",
                },
                {
                    value: "24/7",
                    label: "Soporte",
                    detail: "Acompañamiento continuo antes y después del lanzamiento",
                },
            ],
        },
        mission: {
            badge: "Nuestra misión",
            headlineLines: [
                { text: "Democratizar el acceso a", accent: false },
                { text: "tecnología de alto rendimiento", accent: true },
                { text: "para que más empresas escalen", accent: false },
                { text: "con software optimizado.", accent: true },
            ],
            columns: [
                {
                    title: "Ingeniería experta, resultados reales",
                    body: "Existimos para cerrar la brecha entre las decisiones tecnológicas y los resultados del negocio. No entregamos una recomendación aislada: construimos soluciones concretas que se pueden usar, medir y escalar.",
                },
                {
                    title: "Rendimiento, no solo presencia",
                    body: "Nuestro equipo trabaja diseño, desarrollo y SEO como un mismo sistema. La meta es que tu plataforma no solo se vea mejor, sino que cargue rápido, comunique con claridad y ayude a convertir más oportunidades.",
                },
            ],
        },
        philosophy: {
            badge: "Nuestra filosofía",
            title: "Los valores detrás de cada compromiso",
            cards: [
                {
                    title: "Ejecución sobre retórica",
                    body: "Nos miden por resultados, no por promesas. Cuando VelyonSoft se compromete con un proyecto, el foco está en entregar una solución clara, funcional y lista para operar.",
                },
                {
                    title: "Diseño minimalista con intención",
                    body: "Reducimos ruido visual para que el mensaje sea más fuerte. Cada sección, cada jerarquía y cada interacción están pensadas para orientar, explicar y convertir.",
                },
                {
                    title: "Entrega centrada en el cliente",
                    body: "Alineamos estrategia, SEO y desarrollo con tu contexto real. No trabajamos desde una plantilla cerrada, sino desde lo que tu operación necesita para crecer.",
                },
            ],
        },
        vision: {
            badge: "Nuestra visión",
            headlineLines: [
                { text: "Ser el referente global", accent: false },
                { text: "en desarrollo web donde", accent: true },
                { text: "el diseño minimalista", accent: true },
                { text: "se encuentra con el SEO.", accent: false },
            ],
        },
        reasons: {
            badge: "Por qué elegirnos",
            titleLines: [
                "Experiencia demostrada.",
                "Compromiso inquebrantable.",
            ],
            items: [
                {
                    title: "100% SEO",
                    body: "Arquitectura técnica, velocidad y semántica listas para posicionar mejor desde el inicio.",
                },
                {
                    title: "Diseño minimalista",
                    body: "Interfaces limpias para comunicar rápido, generar confianza y convertir con menos fricción.",
                },
                {
                    title: "+50 casos de éxito",
                    body: "Experiencia aplicada en proyectos reales para empresas que necesitaban orden, visibilidad y crecimiento.",
                },
                {
                    title: "Soporte 24/7",
                    body: "Acompañamiento continuo para mantener tu plataforma estable, clara y optimizada.",
                },
            ],
        },
        profile: {
            badge: "Perfil de la empresa",
            title: "El socio de implementación digital que las empresas eligen para crecer.",
            paragraphs: [
                "Desde Lima, VelyonSoft combina desarrollo web, SEO técnico y software a medida para construir plataformas que ayudan a vender mejor y operar con más claridad.",
                "Trabajamos con empresas que necesitan una presencia digital sólida, una estructura escalable y una ejecución que no se quede en ideas, sino que llegue a producción con criterio técnico.",
            ],
            terminalTitle: "VelyonSoft - Perfil de la empresa",
            terminalLoading: "Cargando perfil...",
            terminalEntries: [
                { label: "Nombre", value: "VelyonSoft" },
                { label: "Base", value: "Lima, Perú" },
                {
                    label: "Enfoque",
                    value: "Desarrollo web, SEO y automatización",
                },
                {
                    label: "Especialidad",
                    value: "Diseño minimalista con rendimiento",
                },
                { label: "Resultados", value: "+50 casos · 100% SEO" },
            ],
            terminalFooter: "Cultura: Claridad · Rendimiento · Ejecución",
        },
        values: {
            badge: "Nuestros valores",
            title: "Qué hace diferente a VelyonSoft",
            cards: [
                {
                    title: "Construimos, no solo asesoramos",
                    body: "La mayoría de equipos propone mejoras. Nosotros aterrizamos la estrategia en una web, un sistema o una automatización que se pueda usar y hacer crecer.",
                },
                {
                    title: "SEO desde la arquitectura",
                    body: "La visibilidad orgánica no se agrega al final. Se define desde la estructura, el contenido, la velocidad y la intención comercial de cada página.",
                },
                {
                    title: "Preparado para escalar",
                    body: "Diseñamos soluciones que hoy se ven limpias y mañana pueden integrar más procesos, más contenido y más oportunidades sin perder claridad.",
                },
            ],
        },
        cta: {
            titleLines: [
                { text: "¿Listo para pasar de la estrategia", accent: false },
                { text: "a la ejecución?", accent: true },
            ],
            body: "Ponte en contacto con nuestro equipo y empieza una implementación digital basada en claridad, SEO y rendimiento real para tu empresa.",
            primary: "Contáctanos",
            secondary: "Ver proyectos",
        },
    },
    en: {
        title: "About Us | Web development, SEO and software | VelyonSoft",
        description:
            "Meet VelyonSoft: web development, technical SEO and optimized software for companies that want to sell better and scale with clarity.",
        breadcrumbHome: "Home",
        breadcrumbCurrent: "About us",
        hero: {
            badge: "About us",
            titleLines: [
                { text: "Engineering-led.", accent: false },
                { text: "Execution-focused.", accent: true },
            ],
            body: "VelyonSoft is a web development, custom software and technical SEO studio. We design, build and optimize digital platforms for companies that want to sell better, operate with more clarity and scale on a solid foundation.",
            primary: "Contact us",
            secondary: "View projects",
            stats: [
                {
                    value: "+5",
                    label: "Years of Innovation",
                    detail: "Digital solutions built with real business focus",
                },
                {
                    value: "+50",
                    label: "Success Cases",
                    detail: "Projects launched for brands and companies seeking clarity",
                },
                {
                    value: "100%",
                    label: "SEO",
                    detail: "Technical architecture, speed and semantics aligned",
                },
                {
                    value: "24/7",
                    label: "Support",
                    detail: "Continuous guidance before and after launch",
                },
            ],
        },
        mission: {
            badge: "Our mission",
            headlineLines: [
                { text: "Democratize access to", accent: false },
                { text: "high-performance technology", accent: true },
                { text: "so more companies can scale", accent: false },
                { text: "through optimized software.", accent: true },
            ],
            columns: [
                {
                    title: "Expert engineering, real outcomes",
                    body: "We exist to close the gap between technology decisions and business outcomes. We do not hand off isolated recommendations: we build practical solutions that can be used, measured and scaled.",
                },
                {
                    title: "Performance, not just presence",
                    body: "Our team treats design, development and SEO as one system. The goal is for your platform to do more than look better: it should load fast, communicate clearly and convert more opportunities.",
                },
            ],
        },
        philosophy: {
            badge: "Our philosophy",
            title: "The values behind every commitment",
            cards: [
                {
                    title: "Execution over rhetoric",
                    body: "We are measured by results, not promises. When VelyonSoft commits to a project, the focus is on delivering a clear, functional solution that is ready to operate.",
                },
                {
                    title: "Minimal design with intention",
                    body: "We reduce visual noise so the message becomes stronger. Every section, hierarchy and interaction is designed to guide, explain and convert.",
                },
                {
                    title: "Client-centered delivery",
                    body: "We align strategy, SEO and development with your real context. We do not work from a closed template, but from what your operation needs in order to grow.",
                },
            ],
        },
        vision: {
            badge: "Our vision",
            headlineLines: [
                { text: "Become the global reference", accent: false },
                { text: "in web development where", accent: true },
                { text: "minimalist design", accent: true },
                { text: "meets SEO.", accent: false },
            ],
        },
        reasons: {
            badge: "Why choose us",
            titleLines: ["Proven experience.", "Unwavering commitment."],
            items: [
                {
                    title: "100% SEO",
                    body: "Technical architecture, speed and semantics prepared to rank better from day one.",
                },
                {
                    title: "Minimal design",
                    body: "Clean interfaces that communicate fast, build trust and convert with less friction.",
                },
                {
                    title: "50+ success cases",
                    body: "Practical experience across real projects for companies seeking structure, visibility and growth.",
                },
                {
                    title: "24/7 support",
                    body: "Continuous guidance to keep your platform stable, clear and optimized.",
                },
            ],
        },
        profile: {
            badge: "Company profile",
            title: "The digital implementation partner companies choose to grow with.",
            paragraphs: [
                "From Lima, VelyonSoft combines web development, technical SEO and custom software to build platforms that help companies sell better and operate with more clarity.",
                "We work with businesses that need a strong digital presence, a scalable foundation and execution that does not stop at ideas, but reaches production with technical judgment.",
            ],
            terminalTitle: "VelyonSoft - Company profile",
            terminalLoading: "Loading profile...",
            terminalEntries: [
                { label: "Name", value: "VelyonSoft" },
                { label: "Base", value: "Lima, Peru" },
                {
                    label: "Focus",
                    value: "Web development, SEO and automation",
                },
                {
                    label: "Specialty",
                    value: "Minimal design with performance",
                },
                { label: "Results", value: "50+ cases · 100% SEO" },
            ],
            terminalFooter: "Culture: Clarity · Performance · Execution",
        },
        values: {
            badge: "Our values",
            title: "What makes VelyonSoft different",
            cards: [
                {
                    title: "We build, not only advise",
                    body: "Most teams suggest improvements. We turn strategy into a website, a system or an automation that can be used and expanded.",
                },
                {
                    title: "SEO from the architecture",
                    body: "Organic visibility is not added at the end. It is defined by the structure, content, speed and commercial intent of every page.",
                },
                {
                    title: "Prepared to scale",
                    body: "We design solutions that look clean today and can support more processes, more content and more opportunities tomorrow without losing clarity.",
                },
            ],
        },
        cta: {
            titleLines: [
                { text: "Ready to move from strategy", accent: false },
                { text: "to execution?", accent: true },
            ],
            body: "Get in touch with our team and start a digital implementation shaped by clarity, SEO and real performance for your business.",
            primary: "Contact us",
            secondary: "View projects",
        },
    },
}[lang];

const schemaData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "AboutPage",
            "@id": `${pageUrl}#webpage`,
            url: pageUrl,
            name: t.title,
            description: t.description,
            inLanguage: lang,
            isPartOf: { "@id": `${site}/#website` },
            about: { "@id": `${site}/#organization` },
            mainEntity: {
                "@type": "Organization",
                "@id": `${site}/#organization`,
                name: "VelyonSoft",
                url: site,
                slogan:
                    lang === "es"
                        ? "Diseño minimalista, SEO técnico y software optimizado para escalar."
                        : "Minimal design, technical SEO and optimized software built to scale.",
            },
        },
        {
            "@type": "BreadcrumbList",
            "@id": `${pageUrl}#breadcrumbs`,
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: t.breadcrumbHome,
                    item: `${site}/${lang}`,
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: t.breadcrumbCurrent,
                    item: pageUrl,
                },
            ],
        },
    ],
};
---

<BaseLayout
    lang={lang}
    title={t.title}
    description={t.description}
    image="/home.webp"
    type="website"
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData)}
        />
    </Fragment>

    <div class="about-page">
        <section class="about-ink about-hero" aria-labelledby="about-title">
            <div class="about-glow about-glow-left" aria-hidden="true"></div>
            <div class="about-glow about-glow-top" aria-hidden="true"></div>
            <div class="about-glow about-glow-center" aria-hidden="true"></div>

            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-hero__inner">
                    <div class="about-kicker about-kicker--dark mx-auto">
                        <span class="about-kicker__dot"></span>
                        {t.hero.badge}
                    </div>

                    <h1
                        id="about-title"
                        class="about-display about-display--hero"
                    >
                        {
                            t.hero.titleLines.map((line) => (
                                <span
                                    class:list={{ "about-accent": line.accent }}
                                >
                                    {line.text}
                                </span>
                            ))
                        }
                    </h1>

                    <p class="about-hero__body">{t.hero.body}</p>
                </div>
            </div>
        </section>

        <section class="about-surface about-surface--lift pt-40">
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-stats-grid">
                    {
                        t.hero.stats.map((item) => (
                            <article class="about-stat-card">
                                <p class="about-stat-card__value">
                                    {item.value}
                                </p>
                                <p class="about-stat-card__label">
                                    {item.label}
                                </p>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section
            class="about-surface about-section"
            aria-labelledby="mission-title"
        >
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-divider-eyebrow">{t.mission.badge}</div>

                <h2
                    id="mission-title"
                    class="about-display about-display--center about-display--light"
                >
                    {
                        t.mission.headlineLines.map((line) => (
                            <span class:list={{ "about-accent": line.accent }}>
                                {line.text}
                            </span>
                        ))
                    }
                </h2>

                <div class="about-copy-grid mt-16">
                    {
                        t.mission.columns.map((item) => (
                            <article>
                                <h3 class="about-copy-title">{item.title}</h3>
                                <p class="about-copy-body">{item.body}</p>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section
            class="about-surface about-section"
            aria-labelledby="philosophy-title"
        >
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-kicker">
                    <span class="about-kicker__dot"></span>
                    {t.philosophy.badge}
                </div>

                <h2 id="philosophy-title" class="about-heading mt-10 max-w-3xl">
                    {t.philosophy.title}
                </h2>

                <div class="about-card-grid mt-14">
                    {
                        t.philosophy.cards.map((card, index) => {
                            const Icon = philosophyIcons[index];
                            return (
                                <article class="about-card">
                                    <span class="about-card__icon">
                                        <Icon size={20} />
                                    </span>
                                    <h3 class="about-card__title">
                                        {card.title}
                                    </h3>
                                    <p class="about-card__body">{card.body}</p>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section
            class="about-ink about-section about-section--compact"
            aria-labelledby="vision-title"
        >
            <div
                class="about-glow about-glow-center about-glow-center--soft"
                aria-hidden="true"
            >
            </div>

            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-divider-eyebrow about-divider-eyebrow--dark">
                    {t.vision.badge}
                </div>

                <h2
                    id="vision-title"
                    class="about-display about-display--center about-display--dark mt-10"
                >
                    {
                        t.vision.headlineLines.map((line) => (
                            <span class:list={{ "about-accent": line.accent }}>
                                {line.text}
                            </span>
                        ))
                    }
                </h2>
            </div>
        </section>

        <section
            class="about-surface about-section"
            aria-labelledby="reasons-title"
        >
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-kicker">
                    <span class="about-kicker__dot"></span>
                    {t.reasons.badge}
                </div>

                <h2 id="reasons-title" class="about-heading mt-10 max-w-3xl">
                    {t.reasons.titleLines.map((line) => <span>{line}</span>)}
                </h2>

                <div class="about-reason-grid mt-16">
                    {
                        t.reasons.items.map((item, index) => {
                            const Icon = reasonIcons[index];
                            return (
                                <article class="about-reason-item">
                                    <span class="about-card__icon">
                                        <Icon size={20} />
                                    </span>
                                    <h3 class="about-reason-item__title">
                                        {item.title}
                                    </h3>
                                    <p class="about-reason-item__body">
                                        {item.body}
                                    </p>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section
            class="about-surface about-section"
            aria-labelledby="profile-title"
        >
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-split-grid">
                    <div>
                        <div class="about-kicker">
                            <span class="about-kicker__dot"></span>
                            {t.profile.badge}
                        </div>

                        <h2
                            id="profile-title"
                            class="about-heading mt-10 max-w-2xl"
                        >
                            {t.profile.title}
                        </h2>

                        <div class="mt-8 space-y-6">
                            {
                                t.profile.paragraphs.map((paragraph) => (
                                    <p class="about-copy-body max-w-xl">
                                        {paragraph}
                                    </p>
                                ))
                            }
                        </div>
                    </div>

                    <div class="about-terminal">
                        <div class="about-terminal__topbar">
                            <span
                                class="about-terminal__window about-terminal__window--red"
                            ></span>
                            <span
                                class="about-terminal__window about-terminal__window--amber"
                            ></span>
                            <span
                                class="about-terminal__window about-terminal__window--green"
                            ></span>
                            <span class="about-terminal__label"
                                >{t.profile.terminalTitle}</span
                            >
                        </div>

                        <div
                            class="about-terminal__body"
                            aria-label={t.profile.terminalTitle}
                        >
                            <p>
                                <span class="about-terminal__prompt">$</span> velyonsoft
                                info --company
                            </p>
                            <p class="about-terminal__muted">
                                {t.profile.terminalLoading}
                            </p>
                            <div class="mt-8 space-y-3">
                                {
                                    t.profile.terminalEntries.map((entry) => (
                                        <p>
                                            <span class="about-terminal__check">
                                                ✓
                                            </span>{" "}
                                            {entry.label}: {entry.value}
                                        </p>
                                    ))
                                }
                            </div>
                            <p class="about-terminal__footer">
                                {t.profile.terminalFooter}
                            </p>
                            <p class="mt-6">
                                <span class="about-terminal__prompt">$</span>
                                <span class="about-terminal__cursor"></span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section
            class="about-surface about-section"
            aria-labelledby="values-title"
        >
            <div class="mx-auto max-w-7xl px-4 sm:px-6">
                <div class="about-kicker">
                    <span class="about-kicker__dot"></span>
                    {t.values.badge}
                </div>

                <h2 id="values-title" class="about-heading mt-10 max-w-4xl">
                    {t.values.title}
                </h2>

                <div class="about-card-grid mt-14">
                    {
                        t.values.cards.map((card, index) => {
                            const Icon = valueIcons[index];
                            return (
                                <article class="about-card about-card--tall">
                                    <span class="about-card__icon">
                                        <Icon size={20} />
                                    </span>
                                    <h3 class="about-card__title">
                                        {card.title}
                                    </h3>
                                    <p class="about-card__body">{card.body}</p>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <section
            class="about-ink about-section about-cta"
            aria-labelledby="about-cta-title"
        >
            <div class="about-glow about-glow-center" aria-hidden="true"></div>

            <div class="mx-auto max-w-7xl px-4 sm:px-6 text-center">
                <h2
                    id="about-cta-title"
                    class="about-display about-display--center about-display--dark"
                >
                    {
                        t.cta.titleLines.map((line) => (
                            <span class:list={{ "about-accent": line.accent }}>
                                {line.text}
                            </span>
                        ))
                    }
                </h2>

                <p class="about-cta__body">{t.cta.body}</p>

                <div class="about-actions justify-center">
                    <a
                        href={quoteHref}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="about-button about-button--solid"
                    >
                        {t.cta.primary}
                    </a>
                    <a
                        href={projectsHref}
                        class="about-button about-button--ghost"
                    >
                        {t.cta.secondary}
                        <ArrowRight class="h-4 w-4" />
                    </a>
