---
export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
  ];
}

import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ServiceLanding from "../../../../components/ServiceLanding.astro";
---

<BaseLayout
    lang="es"
    title="Desarrollo web para empresas en Perú | VelyonSoft"
    description="Diseñamos páginas web para empresas en Perú con SEO técnico, velocidad, contenido comercial e integración con WhatsApp para captar más clientes."
>
    <ServiceLanding
        title="Desarrollo web para empresas"
        description="Crea una presencia digital profesional para tu empresa con una web rápida, moderna y enfocada en generar clientes."
        features={[
            "Diseño responsive",
            "Secciones comerciales",
            "SEO técnico",
            "Formulario de contacto",
            "Integración con WhatsApp",
            "Optimización de velocidad",
        ]}
        benefits={[
            "Mejora la imagen de tu empresa",
            "Aparece mejor en Google",
            "Genera más contactos",
            "Presenta tus servicios de forma clara",
        ]}
        faq={[
            {
                q: "¿La web estará optimizada para Google?",
                a: "Sí. Incluye estructura SEO, meta tags, velocidad y buenas prácticas.",
            },
            {
                q: "¿Puedo pedir varias secciones?",
                a: "Sí. Se define la estructura según los servicios y objetivos de tu empresa.",
            },
        ]}
        whatsappText="Hola, quiero cotizar una página web para empresa."
    />
</BaseLayout>
