---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ArrowUpRight, ChevronLeft } from "lucide-astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
    const projects = await getCollection("proyectos");
    const langs: Lang[] = ["es", "en"];

    return projects.flatMap((project) =>
        langs.map((lang) => ({
            params: {
                lang,
                slug: project.id,
            },
        })),
    );
}

const lang: Lang = Astro.params.lang === "en" ? "en" : "es";
const slug = Astro.params.slug;

if (!slug) {
    throw new Error("Missing project slug");
}

const allProjects = await getCollection("proyectos");
const project = allProjects.find((p) => p.id === slug) as
    | CollectionEntry<"proyectos">
    | undefined;

if (!project) {
    throw new Error(`Project not found: ${slug}`);
}

const { Content } = await render(project);

const site = "https://www.velyonsoft.com";
const pageUrl = `${site}/${lang}/proyectos/${project.id}`;
const projectsHref = `/${lang}/proyectos`;
const projectsLabel = lang === "en" ? "Projects" : "Proyectos";
const ctaLabel = lang === "en" ? "Visit website" : "Visitar sitio";
const pageTitle = `${project.data.title} | ${lang === "es" ? "Caso de estudio" : "Case Study"} | VelyonSoft`;
const schemaData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebPage",
            "@id": `${pageUrl}#webpage`,
            url: pageUrl,
            name: pageTitle,
            description: project.data.description,
            inLanguage: lang,
            isPartOf: { "@id": `${site}/#website` },
            mainEntity: { "@id": `${pageUrl}#article` },
        },
        {
            "@type": "Article",
            "@id": `${pageUrl}#article`,
            headline: project.data.title,
            description: project.data.description,
            image: `${site}${project.data.cover}`,
            datePublished: project.data.date.toISOString(),
            dateModified: project.data.date.toISOString(),
            inLanguage: lang,
            mainEntityOfPage: { "@id": `${pageUrl}#webpage` },
            author: { "@id": `${site}/#organization` },
            publisher: { "@id": `${site}/#organization` },
        },
        {
            "@type": "BreadcrumbList",
            "@id": `${pageUrl}#breadcrumbs`,
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: lang === "es" ? "Inicio" : "Home",
                    item: `${site}/${lang}`,
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: projectsLabel,
                    item: `${site}${projectsHref}`,
                },
                {
                    "@type": "ListItem",
                    position: 3,
                    name: project.data.title,
                    item: pageUrl,
                },
            ],
        },
    ],
};
---

<BaseLayout
    lang={lang}
    title={pageTitle}
    description={project.data.description}
    image={project.data.cover}
    type="article"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    </Fragment>

    <article class="max-w-4xl mx-auto mt-28 px-4 pb-16 sm:px-6 md:mt-[130px] flex flex-col gap-5">
        <nav class="mb-4">
            <div class="flex min-w-0 items-center gap-2 text-muted-foreground text-sm">
                <a
                    href={projectsHref}
                    class="flex shrink-0 items-center gap-1 hover:text-primary transition-colors font-medium"
                >
                    <ChevronLeft class="h-[18px] w-[18px]" stroke-width={2.5} />
                    {projectsLabel}
                </a>
                <span class="text-border">/</span>
                <span class="truncate text-muted-foreground"
                    >{project.data.title}</span
                >
            </div>
        </nav>

        {
            project.data.cover && (
                <img
                    src={project.data.cover}
                    alt={project.data.title}
                    width="1200"
                    height="800"
                    loading="eager"
                    decoding="async"
                    class="w-full rounded-2xl shadow-sm"
                />
            )
        }

        <header>
            <h1 class="text-[2rem] md:text-4xl font-bold leading-tight break-words">
                {project.data.title}
            </h1>

            <p class="text-muted-foreground text-base md:text-lg mt-4 max-w-2xl">
                {project.data.description}
            </p>
        </header>

        <div class="prose prose-neutral dark:prose-invert prose-base md:prose-lg max-w-none prose-img:max-w-full prose-pre:overflow-x-auto">
            <Content />
        </div>

        {
            project.data.url && (
                <div class="mb-16">
                    <a
                        href={project.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${ctaLabel}: ${project.data.title}`}
                        class="inline-flex w-full items-center justify-center gap-2 px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:bg-primary/90 transition sm:w-auto"
                    >
                        {ctaLabel}
                        <ArrowUpRight class="w-5 h-5" />
                    </a>
                </div>
            )
        }
    </article>
</BaseLayout>
