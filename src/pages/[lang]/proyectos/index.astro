---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ArrowUpRight } from "lucide-astro";

type Lang = "es" | "en";

export async function getStaticPaths() {
    return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: Lang };
const site = "https://www.velyonsoft.com";
const pageUrl = `${site}/${lang}/proyectos`;

const t = {
    es: {
        pageTitle: "Portafolio de Proyectos | VelyonSoft",
        pageDesc: "Explora nuestros proyectos de desarrollo web, aplicaciones móviles y soluciones digitales a medida. Casos de éxito reales con resultados medibles.",
        eyebrow: "Portafolio",
        title: "Todos nuestros",
        titleAccent: "Proyectos",
        subtitle: "Soluciones digitales que generan resultados reales para marcas que quieren crecer.",
        viewProject: "Ver caso de estudio",
        count: (n: number) => `${n} proyecto${n !== 1 ? "s" : ""}`,
    },
    en: {
        pageTitle: "Project Portfolio | VelyonSoft",
        pageDesc: "Explore our web development, mobile apps and custom digital solutions. Real success stories with measurable results.",
        eyebrow: "Portfolio",
        title: "All our",
        titleAccent: "Projects",
        subtitle: "Digital solutions that generate real results for brands looking to grow.",
        viewProject: "View case study",
        count: (n: number) => `${n} project${n !== 1 ? "s" : ""}`,
    },
}[lang as "es" | "en"];

const projects = await getCollection("proyectos");

const schemaData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "CollectionPage",
            "@id": `${pageUrl}#webpage`,
            name: t.pageTitle,
            description: t.pageDesc,
            url: pageUrl,
            inLanguage: lang,
            isPartOf: { "@id": `${site}/#website` },
            mainEntity: { "@id": `${pageUrl}#projects` },
        },
        {
            "@type": "ItemList",
            "@id": `${pageUrl}#projects`,
            name: t.pageTitle,
            itemListElement: projects.map((p, i) => ({
                "@type": "ListItem",
                position: i + 1,
                url: `${site}/${lang}/proyectos/${p.id}`,
                item: {
                    "@type": "CreativeWork",
                    name: p.data.title,
                    description: p.data.description,
                    image: `${site}${p.data.cover}`,
                    url: `${site}/${lang}/proyectos/${p.id}`,
                },
            })),
        },
        {
            "@type": "BreadcrumbList",
            "@id": `${pageUrl}#breadcrumbs`,
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: lang === "es" ? "Inicio" : "Home",
                    item: `${site}/${lang}`,
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: t.eyebrow,
                    item: pageUrl,
                },
            ],
        },
    ],
};
---

<BaseLayout lang={lang} title={t.pageTitle} description={t.pageDesc}>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    </Fragment>

    <div class="relative bg-background min-h-screen">

        <!-- Background -->
        <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
            <div class="absolute -top-40 -right-40 h-80 w-80 rounded-full opacity-30 sm:h-[600px] sm:w-[600px]"
                style="background: radial-gradient(circle, #d4eef5 0%, transparent 70%); filter: blur(90px);"></div>
            <div class="absolute bottom-0 -left-32 h-72 w-72 rounded-full opacity-20 sm:h-[400px] sm:w-[400px]"
                style="background: radial-gradient(circle, #cce9f0 0%, transparent 70%); filter: blur(80px);"></div>
            <div class="absolute inset-0 opacity-[0.3]"
                style="
                    background-image: linear-gradient(rgba(13,13,13,0.06) 1px, transparent 1px),
                                      linear-gradient(90deg, rgba(13,13,13,0.06) 1px, transparent 1px);
                    background-size: 60px 60px;
                    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 100%);
                "></div>
        </div>

        <div class="relative z-10 max-w-6xl mx-auto px-4 pt-32 pb-16 sm:px-6 md:pb-24">

            <!-- Header -->
            <header class="mb-12 opacity-0 anim-up md:mb-16 lg:mb-20" style="animation-delay:0.05s">
                <div class="flex items-center gap-3 mb-7">
                    <span class="block w-8 h-px bg-secondary"></span>
                    <span class="text-[0.6rem] font-semibold uppercase tracking-[0.28em] text-secondary">{t.eyebrow}</span>
                </div>
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                    <h1 class="font-display text-[clamp(2.25rem,10vw,5rem)] font-bold leading-[1.02] text-primary tracking-tight m-0">
                        {t.title}<br />
                        <em class="not-italic italic text-secondary">{t.titleAccent}</em>
                    </h1>
                    <div class="max-w-sm md:max-w-xs md:pb-2">
                        <p class="text-[15px] font-light leading-[1.9] text-muted-foreground">{t.subtitle}</p>
                        <p class="text-[0.65rem] font-medium uppercase tracking-[0.2em] text-muted-foreground/40 mt-3">{t.count(projects.length)}</p>
                    </div>
                </div>
            </header>

            <!-- Grid -->
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 list-none p-0 m-0" role="list">
                {projects.map((project, i) => (
                    <li class="flex opacity-0 anim-up" style={`animation-delay:${0.12 + i * 0.07}s`}>
                        <article class="group flex flex-col w-full" itemscope itemtype="https://schema.org/CreativeWork">
                            <meta itemprop="name" content={project.data.title} />
                            <meta itemprop="description" content={project.data.description} />
                            <meta itemprop="image" content={project.data.cover} />

                            <a
                                href={`/${lang}/proyectos/${project.id}`}
                                itemprop="url"
                                aria-label={`${project.data.title} — ${t.viewProject}`}
                                class="card flex flex-col flex-1 no-underline bg-card border border-border rounded-2xl overflow-hidden"
                            >
                                <!-- Image: taller ratio, image does the heavy lifting -->
                                <div class="relative overflow-hidden" style="aspect-ratio: 3/2;">
                                    <img
                                        src={project.data.cover}
                                        alt={project.data.title}
                                        width="640" height="427"
                                        loading="lazy" decoding="async"
                                        class="card-img w-full h-full object-cover"
                                    />
                                    <!-- Soft gradient at bottom of image -->
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>

                                    <!-- Tags: top-left -->
                                    {project.data.tags?.length > 0 && (
                                        <div class="absolute top-3 left-3 flex gap-1.5">
                                            {project.data.tags.slice(0, 2).map((tag: string) => (
                                                <span class="text-[0.55rem] font-medium uppercase tracking-wider px-2 py-0.5 rounded-full bg-background/85 text-primary/80 backdrop-blur-sm">
                                                    {tag}
                                                </span>
                                            ))}
                                        </div>
                                    )}
                                </div>

                                <!-- Content: light, airy, minimal -->
                                <div class="flex flex-col flex-1 px-5 pt-4 pb-5">

                                    <!-- Title: medium weight, not bold -->
                                    <h2 class="card-title mb-1.5 break-words text-[18px] font-medium leading-[1.2] tracking-tight text-primary">
                                        {project.data.title}
                                    </h2>

                                    <!-- Description: the real content -->
                                    <p class="line-clamp-2 flex-1 text-[15px] font-light leading-[1.9] text-muted-foreground">
                                        {project.data.description}
                                    </p>

                                    <!-- Bottom row: just a subtle link, no divider clutter -->
                                    <div class="flex flex-wrap items-center justify-between gap-3 mt-4">
                                        <span class="card-cta text-[0.68rem] font-medium text-muted-foreground/60 tracking-wide">
                                            {t.viewProject}
                                        </span>
                                        <span class="card-arrow flex items-center justify-center w-7 h-7 rounded-full border border-border text-muted-foreground/40">
                                            <ArrowUpRight size={13} />
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </article>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</BaseLayout>

<style>
    .font-display {
        font-family: var(--font-display);
    }

    @keyframes fade-up {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .anim-up {
        animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* ── Card ── */
    .card {
        transition:
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            border-color 0.3s ease;
    }
    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(30, 172, 204, 0.09);
        border-color: rgba(30, 172, 204, 0.3);
    }

    /* Image zoom */
    .card-img {
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .card:hover .card-img {
        transform: scale(1.04);
    }

    /* Title: quietly shifts to secondary */
    .card-title {
        transition: color 0.25s ease;
    }
    .card:hover .card-title {
        color: var(--color-secondary);
    }

    /* CTA text */
    .card-cta {
        transition: color 0.25s ease;
    }
    .card:hover .card-cta {
        color: var(--color-secondary);
    }

    /* Arrow circle fills on hover */
    .card-arrow {
        transition:
            background-color 0.25s ease,
            border-color 0.25s ease,
            color 0.25s ease,
            transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .card:hover .card-arrow {
        background-color: var(--color-secondary);
        border-color: var(--color-secondary);
        color: white;
        transform: rotate(45deg);
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
