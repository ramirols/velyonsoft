---
import {
    Mail,
    MessageCircle,
    ArrowRight,
    ShieldCheck,
    Cpu,
    Instagram,
    Facebook,
    Music,
} from "lucide-astro";

import {
    CONTACT_CONFIG,
    getWhatsAppLink,
    SOCIAL_LINKS,
} from "../lib/constants";

const iconMap = {
    Instagram,
    Facebook,
    Music,
};

type Lang = "es" | "en";
const { lang = "es" } = Astro.props as { lang?: Lang };

const i18n = {
    es: {
        description:
            "Desarrollo web, software a medida y SEO para empresas en Perú",
        nav: "Explorar",
        contact: "Conecta con nosotros",
        footerLabel: "Pie de página",
        rights: "Todos los derechos reservados.",
        legal: "Legal",
        ssl: "Seguridad SSL",
        vitals: "Core Web Vitals",
        waSub: "Chatea con nosotros",
        emailSub: "Escríbenos",
        partner: "Socio tecnológico de confianza",
        performance: "Optimizado para carga ultra-rápida.",
        links: {
            home: "Inicio",
            projects: "Casos de Éxito",
        },
    },
    en: {
        description:
            "Web development, custom software and SEO for companies in Peru",
        nav: "Explore",
        contact: "Connect with us",
        footerLabel: "Footer",
        rights: "All rights reserved.",
        legal: "Legal",
        ssl: "SSL Security",
        vitals: "Core Web Vitals",
        waSub: "Chat with us",
        emailSub: "Send us an email",
        partner: "Trusted technology partner",
        performance: "Optimized for ultra-fast loading.",
        links: {
            home: "Home",
            projects: "Success Stories",
        },
    },
}[lang];

const t = i18n;
---

<footer
    class="relative text-gray-300 overflow-hidden border-t border-white/5"
    aria-labelledby="footer-heading"
>
    <h2 id="footer-heading" class="sr-only">{t.footerLabel}</h2>

    <div
        class="absolute inset-0 bg-gradient-to-br from-zinc-950 via-zinc-800 to-black"
    >
    </div>
    <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(34,211,238,0.08),transparent_60%)]"
    >
    </div>
    <div class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 py-14 md:py-20">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-16 lg:gap-8"
        >
            <div class="space-y-8 sm:col-span-2 lg:col-span-5">
                <div>
                    <a href={`/${lang}#inicio`} class="inline-block group" aria-label="VelyonSoft">
                        <h3
                            class="text-3xl font-bold text-white tracking-tight"
                        >
                            Velyon<span
                                class="text-cyan-400 group-hover:text-cyan-300 transition-colors"
                                >Soft</span
                            >
                        </h3>
                    </a>
                    <p
                        class="mt-6 max-w-md text-balance text-[15px] leading-[1.9] text-white/80"
                    >
                        {t.description}
                    </p>
                </div>

                <div class="flex flex-wrap gap-4">
                    <div
                        class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10"
                    >
                        <ShieldCheck size={14} class="text-secondary" />
                        <span
                            class="text-[10px] uppercase tracking-wider font-medium text-white/70"
                        >
                            {t.ssl}
                        </span>
                    </div>
                    <div
                        class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10"
                    >
                        <Cpu size={14} class="text-secondary" />
                        <span
                            class="text-[10px] uppercase tracking-wider font-medium text-white/70"
                        >
                            {t.vitals}
                        </span>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-3">
                <h4 class="text-sm font-bold text-white uppercase mb-8">
                    {t.nav}
                </h4>
                <ul class="space-y-4" role="list">
                    {
                        [
                            { href: `/${lang}#inicio`, label: t.links.home },
                            {
                                href: `/${lang}/proyectos`,
                                label: t.links.projects,
                            },
                        ].map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="group flex items-center text-[15px] text-white/80 transition-all duration-300 hover:text-secondary"
                                >
                                    <span class="relative">
                                        {item.label}
                                        <span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-secondary transition-all duration-300 group-hover:w-full" />
                                    </span>
                                    <ArrowRight
                                        size={14}
                                        class="ml-2 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ease-out"
                                    />
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div class="lg:col-span-4">
                <h4 class="text-sm font-bold text-white uppercase mb-8">
                    {t.contact}
                </h4>
                <div class="space-y-5">
                    <a
                        href={`mailto:${CONTACT_CONFIG.email}`}
                        aria-label={`Email: ${CONTACT_CONFIG.email}`}
                        class="flex min-w-0 items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-cyan-400/50 transition-all group"
                    >
                        <div
                            class="p-2 rounded-lg bg-cyan-400/10 text-cyan-400 group-hover:scale-110 transition-transform"
                        >
                            <Mail size={20} />
                        </div>
                        <div class="min-w-0">
                            <p
                                class="text-[10px] uppercase text-white/50 font-bold tracking-widest"
                            >
                                Email
                            </p>
                            <p class="truncate text-[15px] leading-[1.8] text-white/80">
                                {t.emailSub}
                            </p>
                        </div>
                    </a>

                    <a
                        href={getWhatsAppLink()}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="WhatsApp VelyonSoft"
                        class="flex items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-green-400/50 transition-all group"
                    >
                        <div
                            class="p-2 rounded-lg bg-green-400/10 text-green-400 group-hover:scale-110 transition-transform"
                        >
                            <MessageCircle size={20} />
                        </div>
                        <div>
                            <p
                                class="text-[10px] uppercase text-white/50 font-bold tracking-widest"
                            >
                                WhatsApp
                            </p>
                            <p class="text-[15px] leading-[1.8] text-white/80">{t.waSub}</p>
                        </div>
                    </a>
                </div>
            </div>

            <div class="lg:col-span-3">
                <h4 class="text-sm font-bold text-white uppercase mb-8">
                    {lang === "es" ? "Síguenos" : "Follow us"}
                </h4>
                <div class="flex flex-col gap-3">
                    {
                        SOCIAL_LINKS.map((social) => {
                            const IconComponent =
                                iconMap[
                                    social.iconName as keyof typeof iconMap
                                ];

                            return (
                                <a
                                    href={social.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={`${social.name} VelyonSoft`}
                                    class={`flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/10 transition-all group ${social.color} backdrop-blur-sm`}
                                >
                                    <div
                                        class={`p-2 rounded-lg ${social.bgColor} ${social.iconColor} group-hover:scale-110 transition-transform`}
                                    >
                                        {IconComponent && (
                                            <IconComponent size={18} />
                                        )}
                                    </div>
                                    <span class="text-[15px] text-white/80 transition-colors group-hover:text-white">
                                        {social.name}
                                    </span>
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 mt-12 md:mt-20">
            <div
                class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6"
            >
                <div class="flex flex-col gap-1">
                    <p
                        class="text-white text-[11px] font-medium uppercase tracking-widest text-center md:text-left"
                    >
                        © {new Date().getFullYear()} VelyonSoft Digital Agency
                    </p>
                    <p
                        class="text-white/60 text-[10px] text-center md:text-left"
                    >
                        {t.rights}
                        {t.performance}
                    </p>
                </div>

                <div
                    class="group flex items-center gap-3 px-4 py-2 rounded-xl bg-gradient-to-r from-white/5 to-transparent border border-white/10"
                >
                    <div class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"
                        ></span>
                    </div>
                    <span
                        class="text-[10px] text-white/60 font-bold tracking-tighter uppercase group-hover:text-white transition-colors"
                    >
                        {t.partner}
                    </span>
                </div>
            </div>
        </div>
    </div>
</footer>
