---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
	lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;

const site = "https://www.velyonsoft.com";
const pathname = Astro.url.pathname;

const cleanPath = pathname.replace(/^\/(es|en)(\/|$)/, "/");
const normalizedPath = cleanPath === "" ? "/" : cleanPath;

const canonical =
	lang === "es"
		? `${site}/es${normalizedPath === "/" ? "" : normalizedPath}`
		: `${site}/en${normalizedPath === "/" ? "" : normalizedPath}`;

const alternateEs = `${site}/es${normalizedPath === "/" ? "" : normalizedPath}`;
const alternateEn = `${site}/en${normalizedPath === "/" ? "" : normalizedPath}`;
const xDefault = `${site}/es${normalizedPath === "/" ? "" : normalizedPath}`;
---

<!doctype html>
<html lang={lang}>
	<head>
		<ClientRouter />
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>

		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link rel="dns-prefetch" href="https://fonts.gstatic.com" />
		<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.clarity.ms" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="icon"
			type="image/png"
			sizes="96x96"
			href="/favicon-96x96.png"
		/>
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preload" as="image" href="/velyon-logo-mc.webp" />
		<link rel="preload" as="image" href="/velyon-logo-mo.webp" />

		<link rel="sitemap" href="/sitemap-index.xml" />

		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="es" href={alternateEs} />
		<link rel="alternate" hreflang="en" href={alternateEn} />
		<link rel="alternate" hreflang="x-default" href={xDefault} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700;800&family=Instrument+Sans:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600;700&display=swap"
			media="print"
			onload="this.media='all'"
		/>

		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="VelyonSoft" />
		<meta name="theme-color" content="#ffffff" />

		<meta name="msvalidate.01" content="F642000EE1A0DC0A49E6AB0A92B9AAB0" />

		<meta name="application-name" content="VelyonSoft" />
		<meta name="apple-mobile-web-app-title" content="VelyonSoft" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>

		<meta
			name="robots"
			content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
		/>
		<meta name="googlebot" content="index,follow,max-image-preview:large" />
		<meta
			name="format-detection"
			content="telephone=no, email=no, address=no"
		/>
		<meta name="referrer" content="strict-origin-when-cross-origin" />

		<script is:inline>
			(() => {
				const media = window.matchMedia("(prefers-color-scheme: dark)");
				let themeTransitionTimeout;

				const getSystemTheme = () => (media.matches ? "dark" : "light");

				const startThemeTransition = () => {
					const root = document.documentElement;

					window.clearTimeout(themeTransitionTimeout);
					root.dataset.themeTransition = "active";
					themeTransitionTimeout = window.setTimeout(() => {
						delete root.dataset.themeTransition;
					}, 190);
				};

				const applyTheme = (theme, transition = false) => {
					const root = document.documentElement;
					const meta = document.querySelector(
						'meta[name="theme-color"]',
					);
					const isDark = theme === "dark";

					if (transition) {
						startThemeTransition();
					}

					root.classList.toggle("dark", isDark);
					root.dataset.theme = theme;
					meta?.setAttribute(
						"content",
						isDark ? "#091017" : "#ffffff",
					);
					document.dispatchEvent(
						new CustomEvent("themechange", { detail: { theme } }),
					);
				};

				const getTheme = () =>
					window.__themeOverride || getSystemTheme();

				window.__setTheme = (theme) => {
					window.__themeOverride = theme;
					applyTheme(theme, true);
				};

				window.__resetTheme = () => {
					delete window.__themeOverride;
					applyTheme(getSystemTheme(), true);
				};

				window.__setThemePreference = window.__setTheme;
				window.__getTheme = getTheme;
				window.__getThemePreference = getTheme;
				window.__applyTheme = (theme) => {
					window.__themeOverride = theme;
					applyTheme(theme, true);
				};

				applyTheme(getTheme());

				const restoreTheme = () => {
					applyTheme(getTheme());
				};

				document.addEventListener("astro:after-swap", restoreTheme);
				document.addEventListener("astro:page-load", restoreTheme);

				const syncSystemTheme = () => {
					if (window.__themeOverride) {
						return;
					}

					applyTheme(getSystemTheme());
				};

				if (media.addEventListener) {
					media.addEventListener("change", syncSystemTheme);
				} else {
					media.addListener(syncSystemTheme);
				}
			})();
		</script>

		<slot name="head" />
	</head>
	<body>
		<div id="page-loader" class="page-loader" aria-hidden="true">
			<div class="page-loader__inner">
				<div class="page-loader__logo" aria-label="VelyonSoft cargando">
					<img
						id="page-loader-logo"
						class="page-loader__logo-image"
						src="/velyon-logo-mc.webp"
						alt=""
						loading="eager"
						decoding="async"
					/>
				</div>

				<div class="page-loader__line" aria-hidden="true">
					<span></span>
				</div>
			</div>
		</div>

		<slot />
		<script is:inline>
			(() => {
				if (window.__velyonHeaderScrollBound) return;
				window.__velyonHeaderScrollBound = true;

				const getScrollY = () =>
					window.scrollY ||
					window.pageYOffset ||
					document.documentElement.scrollTop ||
					document.body.scrollTop ||
					0;

				let lastScrollY = getScrollY();
				let ticking = false;

				const getHeader = () =>
					document.querySelector("[data-site-header]");

				const setHeaderHidden = (hidden) => {
					const header = getHeader();

					if (!header) return;

					const mobileMenuOpen =
						header.dataset.mobileNavOpen === "true";
					header.classList.toggle(
						"is-hidden",
						hidden && !mobileMenuOpen,
					);
				};

				const updateHeaderVisibility = () => {
					const currentScrollY = getScrollY();
					const delta = currentScrollY - lastScrollY;
					const header = getHeader();

					if (!header) {
						lastScrollY = currentScrollY;
						ticking = false;
						return;
					}

					if (
						currentScrollY <= 24 ||
						header.dataset.mobileNavOpen === "true"
					) {
						setHeaderHidden(false);
						lastScrollY = currentScrollY;
						ticking = false;
						return;
					}

					if (delta > 8) {
						setHeaderHidden(true);
						lastScrollY = currentScrollY;
					} else if (delta < -8) {
						setHeaderHidden(false);
						lastScrollY = currentScrollY;
					}

					ticking = false;
				};

				const onScroll = () => {
					if (ticking) return;

					ticking = true;
					window.requestAnimationFrame(updateHeaderVisibility);
				};

				const resetHeaderVisibility = () => {
					lastScrollY = getScrollY();
					setHeaderHidden(false);
				};

				window.addEventListener("scroll", onScroll, { passive: true });
				document.addEventListener("scroll", onScroll, {
					passive: true,
					capture: true,
				});
				document.addEventListener(
					"astro:after-swap",
					resetHeaderVisibility,
				);
				document.addEventListener(
					"astro:page-load",
					resetHeaderVisibility,
				);

				resetHeaderVisibility();
			})();

			(() => {
				if (window.__velyonPageLoaderBound) return;
				window.__velyonPageLoaderBound = true;

				const SHOW_DELAY_MS = 120;
				const MIN_VISIBLE_MS = 220;
				const COMPLETE_DELAY_MS = 120;
				const PROGRESS_START = 0.08;
				const PROGRESS_PREPARED = 0.68;
				const PROGRESS_SWAP = 0.9;

				const getLoader = () => document.getElementById("page-loader");
				const getLoaderLogo = () =>
					document.getElementById("page-loader-logo");

				const loaderState = {
					active: false,
					visible: false,
					progress: 0,
					startedAt: 0,
					visibleAt: 0,
					progressFrame: 0,
					showTimeout: 0,
					hideTimeout: 0,
				};

				const clearLoaderTimers = () => {
					window.clearTimeout(loaderState.showTimeout);
					window.clearTimeout(loaderState.hideTimeout);
					window.cancelAnimationFrame(loaderState.progressFrame);
					loaderState.showTimeout = 0;
					loaderState.hideTimeout = 0;
					loaderState.progressFrame = 0;
				};

				const syncLoaderLogo = () => {
					const logo = getLoaderLogo();
					if (!(logo instanceof HTMLImageElement)) return;

					logo.src = document.documentElement.classList.contains(
						"dark",
					)
						? "/velyon-logo-mo.webp"
						: "/velyon-logo-mc.webp";
				};

				const setLoaderProgress = (value, force = false) => {
					const loader = getLoader();
					if (!loader) return;

					const nextValue = Math.min(Math.max(value, 0), 1);
					loaderState.progress = force
						? nextValue
						: Math.max(loaderState.progress, nextValue);
					loader.style.setProperty(
						"--page-loader-progress",
						loaderState.progress.toFixed(3),
					);
				};

				const resetLoader = () => {
					const loader = getLoader();
					if (!loader) return;

					clearLoaderTimers();
					loaderState.active = false;
					loaderState.visible = false;
					loaderState.progress = 0;
					loader.classList.remove("is-active");
					loader.setAttribute("aria-hidden", "true");
					loader.style.setProperty("--page-loader-progress", "0");
					delete document.documentElement.dataset.pageLoading;
				};

				const updateLoaderProgress = () => {
					if (!loaderState.active) {
						return;
					}

					const elapsed = performance.now() - loaderState.startedAt;
					const easedProgress =
						PROGRESS_START +
						(0.84 - PROGRESS_START) *
							(1 - Math.exp(-elapsed / 700));

					setLoaderProgress(easedProgress);
					loaderState.progressFrame =
						window.requestAnimationFrame(updateLoaderProgress);
				};

				const revealLoader = () => {
					const loader = getLoader();
					if (!loader || !loaderState.active || loaderState.visible)
						return;

					loaderState.visible = true;
					loaderState.visibleAt = performance.now();
					loader.classList.add("is-active");
					loader.setAttribute("aria-hidden", "false");
					document.documentElement.dataset.pageLoading = "true";
				};

				const showLoader = () => {
					const loader = getLoader();
					if (!loader) return;

					syncLoaderLogo();
					clearLoaderTimers();
					loaderState.active = true;
					loaderState.visible = false;
					loaderState.startedAt = performance.now();
					loader.classList.remove("is-active");
					loader.setAttribute("aria-hidden", "true");
					setLoaderProgress(PROGRESS_START, true);

					loaderState.showTimeout = window.setTimeout(
						revealLoader,
						SHOW_DELAY_MS,
					);
					loaderState.progressFrame =
						window.requestAnimationFrame(updateLoaderProgress);
				};

				const advanceLoader = (value) => {
					if (!loaderState.active) return;
					setLoaderProgress(value);
				};

				const hideLoader = () => {
					const loader = getLoader();
					if (!loader) return;

					window.clearTimeout(loaderState.showTimeout);
					window.cancelAnimationFrame(loaderState.progressFrame);
					loaderState.showTimeout = 0;
					loaderState.progressFrame = 0;

					if (!loaderState.active) {
						resetLoader();
						return;
					}

					loaderState.active = false;
					setLoaderProgress(1, true);

					if (!loaderState.visible) {
						resetLoader();
						return;
					}

					const visibleElapsed =
						performance.now() - loaderState.visibleAt;
					const hideDelay = Math.max(
						0,
						MIN_VISIBLE_MS - visibleElapsed,
					);

					loaderState.hideTimeout = window.setTimeout(() => {
						loader.classList.remove("is-active");
						loader.setAttribute("aria-hidden", "true");
						delete document.documentElement.dataset.pageLoading;
						loaderState.visible = false;
					}, hideDelay + COMPLETE_DELAY_MS);
				};

				document.addEventListener(
					"astro:before-preparation",
					showLoader,
				);
				document.addEventListener("astro:after-preparation", () => {
					advanceLoader(PROGRESS_PREPARED);
				});
				document.addEventListener("astro:before-swap", () => {
					advanceLoader(PROGRESS_SWAP);
				});
				document.addEventListener("astro:after-swap", () => {
					advanceLoader(0.96);
				});
				document.addEventListener("astro:page-load", hideLoader);

				window.addEventListener("pageshow", resetLoader);
				document.addEventListener("themechange", syncLoaderLogo);
				document.addEventListener("astro:page-load", syncLoaderLogo);
				syncLoaderLogo();
				resetLoader();
			})();
		</script>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
		background-color: var(--color-background);
		scrollbar-color: var(--color-secondary) var(--color-background);
		scrollbar-width: thin;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	[data-site-header] {
		transform: translate3d(0, 0, 0);
		opacity: 1;
		will-change: transform, opacity;
		view-transition-name: none;
	}

	[data-site-header] * {
		view-transition-name: none;
	}

	[data-theme-transition="active"] [data-site-header],
	[data-theme-transition="active"]
		[data-site-header]
		:where(a, button, div, span, nav, p) {
		transition-duration: 160ms;
		transition-property:
			background-color, border-color, box-shadow, color, opacity,
			transform;
		transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
	}

	[data-site-header] img {
		aspect-ratio: 106 / 24;
		contain: paint;
	}

	[data-site-header] .header-nav-link {
		color: var(--primary);
		transition:
			color 150ms ease,
			opacity 150ms ease;
	}

	[data-site-header] .header-nav-link:hover {
		color: var(--secondary);
	}

	[data-site-header] .header-nav-link[data-active="true"] {
		color: var(--secondary);
	}

	[data-site-header].is-hidden {
		transform: translate3d(0, calc(-100% - 2rem), 0);
		opacity: 0;
		pointer-events: none;
	}
</style>
