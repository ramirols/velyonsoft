---
import Layout from "./Layout.astro";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.astro";
import WhatsAppWidget from "@/components/WhatsAppWidget";

interface Props {
    lang?: "es" | "en";
    title?: string;
    description?: string;
    image?: string;
    type?: "website" | "article";
}

const {
  lang = "es",
  title = lang === "es"
    ? "Desarrollo web y software para negocios en Perú | VelyonSoft"
    : "Web development and software for businesses in Peru | VelyonSoft",
  description = lang === "es"
    ? "Creamos páginas web, sistemas y automatizaciones para negocios en Perú."
    : "We build websites, systems and automations for businesses in Peru.",
  image = "/og-default.jpg",
  type = "website",
} = Astro.props as Props;

const site = "https://www.velyonsoft.com";
const pathname = Astro.url.pathname;

const cleanPath = pathname.replace(/^\/(es|en)(\/|$)/, "/");
const normalizedPath = cleanPath === "" ? "/" : cleanPath;

const canonical =
    lang === "es"
        ? `${site}/es${normalizedPath === "/" ? "" : normalizedPath}`
        : `${site}/en${normalizedPath === "/" ? "" : normalizedPath}`;

const absoluteImage = image.startsWith("http") ? image : `${site}${image}`;
const ogLocale = lang === "es" ? "es_PE" : "en_US";

const ldData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Organization",
            "@id": `${site}/#organization`,
            name: "VelyonSoft",
            url: site,
            logo: `${site}/logo.png`,
            sameAs: [
                "https://facebook.com/velyonsoft",
                "https://instagram.com/velyonsoft",
                "https://linkedin.com/company/velyonsoft",
                "https://x.com/VelyonSoft",
            ],
        },
        {
            "@type": "ProfessionalService",
            "@id": `${canonical}#service`,
            name: "VelyonSoft",
            url: canonical,
            image: absoluteImage,
            telephone: "+51997676432",
            priceRange: "$$",
            areaServed: "PE",
            address: {
                "@type": "PostalAddress",
                streetAddress: "Av. Argentina 358",
                addressLocality: "Comas",
                addressRegion: "Lima",
                addressCountry: "PE",
            },
            openingHoursSpecification: {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                    "Monday",
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday",
                ],
                opens: "09:00",
                closes: "18:00",
            },
        },
        {
            "@type": "WebSite",
            "@id": `${site}/#website`,
            url: site,
            name: "VelyonSoft",
            inLanguage: lang,
        },
    ],
};
---

<Layout lang={lang}>
    <Fragment slot="head">
        <title>{title}</title>
        <meta name="description" content={description} />

        <meta property="og:type" content={type} />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content="VelyonSoft" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={absoluteImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@VelyonSoft" />
        <meta name="twitter:creator" content="@VelyonSoft" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={absoluteImage} />

        <script type="application/ld+json" set:html={JSON.stringify(ldData)} />

        <slot name="head" />

        <script
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-D74ZW26T1V"
        ></script>

        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-D74ZW26T1V");
        </script>

        <script is:inline>
            (function (c, l, a, r, i, t, y) {
                c[a] =
                    c[a] ||
                    function () {
                        (c[a].q = c[a].q || []).push(arguments);
                    };
                t = l.createElement(r);
                t.async = 1;
                t.src = "https://www.clarity.ms/tag/" + i;
                y = l.getElementsByTagName(r)[0];
                y.parentNode.insertBefore(t, y);
            })(window, document, "clarity", "script", "w2dxs0wpy6");
        </script>
    </Fragment>

    <Header client:load transition:persist lang={lang} pathname={pathname} />

    <main id="main-content">
        <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppWidget client:idle />
</Layout>
